---
import "../styles/global.css";
import AboutSection from "../components/about-section.astro";
import CertificationsSection from "../components/certifications-section.astro";
import ClientRuntime from "../components/client-runtime.astro";
import ContactSection from "../components/contact-section.astro";
import HomeSection from "../components/home-section.astro";
import Navbar from "../components/navbar.astro";
import ProjectsSection from "../components/projects-section.astro";
import SkillsSection from "../components/skills-section.astro";
import { messages } from "../data/i18n";
import { defaultLocale } from "../data/locales";
import { profile } from "../data/profile";

const locale = defaultLocale;
const t = messages[locale];
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={profile.description} />
    <title>{t["site.title"]}</title>
    <script is:inline>
      const storedTheme = localStorage.getItem("theme") || "dark";
      const storedLocale = localStorage.getItem("locale") || "pt";
      document.documentElement.dataset.theme = storedTheme;
      document.documentElement.lang = storedLocale;
    </script>
  </head>
  <body>
    <div class="site-shell">
      <Navbar t={t} locale={locale} />
      <main>
        <HomeSection t={t} />
        <AboutSection t={t} />
        <SkillsSection t={t} />
        <ProjectsSection t={t} />
        <CertificationsSection t={t} />
        <ContactSection t={t} />
      </main>
    </div>
    <ClientRuntime messages={messages} />
  </body>
</html>
