---
import { Icon } from "astro-icon/components";
import { aboutSections } from "../data/about";

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section id="about" class="section container-page">
  <h2 class="section-title" data-i18n="about.title">{t["about.title"]}</h2>
  <div class="mx-auto grid max-w-5xl gap-4">
    {aboutSections.map((section) => (
      <article class="content-card">
        <button
          class="flex w-full items-center justify-between gap-4 text-left text-lg font-bold"
          type="button"
          data-collapse-trigger
          aria-expanded={section.initiallyOpen ? "true" : "false"}
        >
          <span class="collapse-title" data-i18n={section.titleKey}>{t[section.titleKey]}</span>
          <span class="collapse-icon" aria-hidden="true">
            <Icon name="mdi:keyboard-arrow-down" class="collapse-icon-collapsed h-6 w-6" />
            <Icon name="mdi:keyboard-arrow-right" class="collapse-icon-expanded h-6 w-6" />
          </span>
        </button>
        <div
          class="collapse-panel"
          style="color: var(--muted)"
          aria-hidden={section.initiallyOpen ? "false" : "true"}
          data-collapse-panel
        >
          <div class="collapse-panel-content" data-i18n-html={section.bodyKey} set:html={t[section.bodyKey]} />
        </div>
      </article>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll("[data-collapse-trigger]").forEach((trigger) => {
    const panel = trigger.parentElement?.querySelector("[data-collapse-panel]");
    const expanded = trigger.getAttribute("aria-expanded") === "true";
    panel?.setAttribute("aria-hidden", String(!expanded));

    trigger.addEventListener("click", () => {
      const panel = trigger.parentElement?.querySelector("[data-collapse-panel]");
      const expanded = trigger.getAttribute("aria-expanded") === "true";
      trigger.setAttribute("aria-expanded", String(!expanded));
      panel?.setAttribute("aria-hidden", String(expanded));
    });
  });
</script>
