---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section id="projects" class="section container-page">
  <h2 class="section-title" data-i18n="projects.title">{t["projects.title"]}</h2>
  <p id="projects-status" class="text-center" style="color: var(--muted)" data-i18n="projects.loading">{t["projects.loading"]}</p>
  <div id="projects-grid" class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-page-size="6"></div>
  <div id="projects-pagination" class="mt-8 flex justify-center gap-2"></div>
</section>

<script>
  // @ts-nocheck
  let projects = [];
  let currentProjectPage = 1;

  function getLocale() {
    return localStorage.getItem("locale") || "pt";
  }

  function paginateProjects(page = 1) {
    const messages = window.PORTFOLIO_MESSAGES || { pt: {} };
    const grid = document.querySelector("#projects-grid");
    const pager = document.querySelector("#projects-pagination");
    if (!grid || !pager || projects.length === 0) return;

    const dictionary = messages[getLocale()] || messages.pt;
    const pageSize = Number(grid.dataset.pageSize || 6);
    const totalPages = Math.max(1, Math.ceil(projects.length / pageSize));
    const safePage = Math.min(Math.max(page, 1), totalPages);
    currentProjectPage = safePage;

    grid.innerHTML = "";
    projects.slice((safePage - 1) * pageSize, safePage * pageSize).forEach((project) => {
      const card = document.createElement("article");
      card.className = "content-card flex min-h-52 flex-col";
      card.innerHTML = `
        <h3 class="mb-4 text-xl font-bold break-words"></h3>
        <p class="mb-5 line-clamp-3 flex-1 leading-7" style="color: var(--muted)"></p>
        <a class="primary-link" target="_blank" rel="noreferrer"></a>
      `;
      card.querySelector("h3").textContent = project.name;
      card.querySelector("p").textContent = project.description || "";
      const link = card.querySelector("a");
      link.href = project.html_url;
      link.textContent = dictionary["projects.access"] || "Access repository";
      grid.appendChild(card);
    });

    pager.innerHTML = "";
    for (let pageNumber = 1; pageNumber <= totalPages; pageNumber += 1) {
      const button = document.createElement("button");
      button.className = "pagination-button";
      button.type = "button";
      button.textContent = String(pageNumber);
      if (pageNumber === safePage) button.setAttribute("aria-current", "page");
      button.addEventListener("click", () => paginateProjects(pageNumber));
      pager.appendChild(button);
    }
  }

  window.renderProjectsForLocale = () => paginateProjects(currentProjectPage);

  async function setupProjects() {
    const status = document.querySelector("#projects-status");
    const messages = window.PORTFOLIO_MESSAGES || { pt: {} };
    try {
      const response = await fetch("https://api.github.com/users/dheovani/repos");
      projects = await response.json();
      if (!Array.isArray(projects) || projects.length === 0) throw new Error("empty");
      status?.classList.add("hidden");
      paginateProjects(1);
    } catch {
      const dictionary = messages[getLocale()] || messages.pt;
      if (status) status.textContent = dictionary["projects.empty"] || "Projects could not be loaded right now.";
    }
  }

  setupProjects();
</script>
