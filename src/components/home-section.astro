---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { profile } from "../data/profile";
import { techStack } from "../data/tech-stack";

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section id="home" class="section container-page min-h-[calc(100vh-4rem)]">
  <div class="grid min-h-[68vh] items-center gap-12 lg:grid-cols-[minmax(0,1fr)_380px]">
    <div class="mx-auto max-w-2xl text-center lg:mx-0 lg:text-left">
      <p class="mb-6 text-4xl font-bold leading-tight sm:text-5xl" data-i18n-html="home.greeting" set:html={t["home.greeting"]} />
      <div
        class="home-copy mx-auto max-w-[42rem] space-y-3 text-left text-base leading-8 sm:text-lg lg:mx-0"
        style="color: var(--muted)"
        data-i18n-html="home.description"
        set:html={t["home.description"]}
      />
    </div>
    <div class="hidden justify-end lg:flex">
      <Image
        src={profile.image}
        width={720}
        height={720}
        alt={profile.name}
        format="webp"
        quality={95}
        fit="cover"
        position="center"
        loading="eager"
        decoding="async"
        class="home-portrait h-[360px] w-[360px] rounded-full object-cover shadow-2xl"
        style="box-shadow: 0 0 28px color-mix(in srgb, var(--accent) 34%, transparent)"
      />
    </div>
  </div>

  <div class="tech-badge-list mx-auto mt-10 max-w-5xl">
    {techStack.map((tech) => (
      <span class="tech-badge" data-tone={tech.tone}>
        <span class="tech-badge-icon">
          <Icon name={tech.icon} class="h-4 w-4" aria-hidden="true" />
        </span>
        <span>{tech.label}</span>
      </span>
    ))}
  </div>
</section>
